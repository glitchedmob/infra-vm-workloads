apiVersion: v1
kind: ConfigMap
metadata:
  name: argocd-cm
  namespace: argocd
  labels:
    app.kubernetes.io/name: argocd-cm
    app.kubernetes.io/part-of: argocd
data:
  url: https://argocd.levizitting.com
  server.insecure: "true"
  admin.enabled: "true"
  dex.config: |
    connectors:
      - type: github
        id: github
        name: GitHub
        config:
          clientID: {{ argocd_github_oauth_client_id }}
          clientSecret: $argocd-github-oauth:dex.github.clientSecret
          orgs:
          - name: glitchedmob
